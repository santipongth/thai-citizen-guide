# Copy this file to .env and fill in your values

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="AI Chatbot Portal API"
APP_VERSION="1.0.0"
DEBUG=false

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Format: postgres://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgres://postgres:password@localhost:5432/ai_chatbot

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (JSON array format)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── LLM (AI Gateway) ─────────────────────────────────────────────────────────
# Leave LLM_API_KEY empty to skip LLM synthesis (answers will be raw agency data)
LLM_API_KEY=
LLM_API_URL=https://ai.gateway.lovable.dev/v1/chat/completions
LLM_MODEL=google/gemini-3-flash-preview

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
